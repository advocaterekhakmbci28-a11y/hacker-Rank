import re

def validate_mobile(n):
    # Pattern: ^ start, [789] first digit, \d{9} nine more digits, $ end
    pattern = r'^[789]\d{9}$'
    if re.match(pattern, n):
        return "YES"
    else:
        return "NO"

# Reading input
import sys
input_data = sys.stdin.read().split()
if len(input_data) > 0:
    t = int(input_data[0])
    for i in range(1, t + 1):
        print(validate_mobile(input_data[i]))
