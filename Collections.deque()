from collections import deque
import sys

def solve():
    try:
        line1 = sys.stdin.readline()
        if not line1:
            return
        n = int(line1.strip())
    except ValueError:
        return
    d = deque()
    for _ in range(n):
        command = sys.stdin.readline().split()
        if not command:
            break  
        method = command[0] 
        if len(command) > 1:
            value = command[1]
            getattr(d, method)(value)
        else:
            getattr(d, method)()
    print(" ".join(d))
if __name__ == '__main__':
    solve()
