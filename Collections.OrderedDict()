from collections import OrderedDict
net_prices = OrderedDict()
try:
    n = int(input())
except EOFError:
    n = 0
for _ in range(n):
    entry = input().split()
    price = int(entry[-1])
    item_name = " ".join(entry[:-1])
    if item_name in net_prices:
        net_prices[item_name] += price
    else:
        net_prices[item_name] = price
for item, total_price in net_prices.items():
    print(f"{item} {total_price}")
